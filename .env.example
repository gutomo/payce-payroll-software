# Local development environment.
# Synthetic/dev values only — NEVER put real secrets or real PII here.
# In AWS, all secrets come from Secrets Manager / SSM (see docs/aws-architecture.md §7).

NODE_ENV=development

# Web (Next.js)
WEB_PORT=3000
NEXT_PUBLIC_APP_NAME=Payce

# API (NestJS)
API_PORT=4000

# Postgres (docker compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=payce
POSTGRES_PASSWORD=payce_dev_password
POSTGRES_DB=payce_dev
DATABASE_URL=postgresql://payce:payce_dev_password@localhost:5432/payce_dev?schema=public

# Redis (docker compose)
REDIS_URL=redis://localhost:6379

# LocalStack (AWS emulation)
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
