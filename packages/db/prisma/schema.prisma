// Payce data spine. Multi-tenancy = shared schema + mandatory tenant_id on tenant-owned rows,
// enforced by (a) the tenant-scoped Prisma client (src/tenant.ts) and (b) Postgres Row-Level
// Security (prisma/migrations/*_rls). See docs/data-model.md and PLAN.md §8.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Runtime/app connection: the least-privilege `payce_app` role, which RLS applies to.
  url       = env("DATABASE_URL")
  // Migrations/introspection connect as the schema owner (superuser-free but privileged).
  directUrl = env("DIRECT_DATABASE_URL")
}

// ─────────────────────────── Platform plane (NOT tenant-scoped) ───────────────────────────

enum TenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

model Plan {
  id        String   @id @default(uuid(7))
  key       String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenants Tenant[]

  @@map("plan")
}

model Tenant {
  id        String       @id @default(uuid(7))
  slug      String       @unique
  name      String
  status    TenantStatus @default(PENDING)
  planId    String?      @map("plan_id")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  createdBy String?      @map("created_by")
  updatedBy String?      @map("updated_by")

  plan          Plan?          @relation(fields: [planId], references: [id])
  users         User[]
  credentials   Credential[]
  roles         Role[]
  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  legalEntities LegalEntity[]
  departments   Department[]
  auditEvents   AuditEvent[]

  locations           Location[]
  costCenters         CostCenter[]
  employees           Employee[]
  employmentRecords   EmploymentRecord[]
  compensationRecords CompensationRecord[]
  payGroups           PayGroup[]
  payCalendars        PayCalendar[]
  payPeriods          PayPeriod[]
  payrollRuns         PayrollRun[]
  payrollRunLines     PayrollRunLine[]
  approvals           Approval[]
  anomalies           Anomaly[]
  payslipDocuments    PayslipDocument[]
  bankFiles           BankFile[]
  leaveTypes          LeaveType[]
  leaveBalances       LeaveBalance[]
  leaveRequests       LeaveRequest[]
  claims              Claim[]
  claimAttachments    ClaimAttachment[]

  @@map("tenant")
}

// Global permission catalog — reference data shared across tenants (keys are the source of truth in @payce/rbac).
model Permission {
  id          String @id @default(uuid(7))
  key         String @unique
  description String

  @@map("permission")
}

// ─────────────────────────── Identity (tenant-scoped, RLS) ───────────────────────────

enum UserStatus {
  INVITED
  ACTIVE
  DISABLED
}

model User {
  id          String     @id @default(uuid(7))
  tenantId    String     @map("tenant_id")
  email       String
  displayName String     @map("display_name")
  status      UserStatus @default(INVITED)
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  createdBy   String?    @map("created_by")
  updatedBy   String?    @map("updated_by")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  credential    Credential?
  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  employee      Employee?

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("app_user")
}

model Credential {
  id           String   @id @default(uuid(7))
  tenantId     String   @map("tenant_id")
  userId       String   @unique @map("user_id")
  passwordHash String   @map("password_hash")
  mfaSecret    String?  @map("mfa_secret")
  mfaEnabled   Boolean  @default(false) @map("mfa_enabled")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("credential")
}

model Role {
  id             String   @id @default(uuid(7))
  tenantId       String   @map("tenant_id")
  key            String
  name           String
  isSystem       Boolean  @default(false) @map("is_system")
  permissionKeys String[] @map("permission_keys")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles UserRole[]

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("role")
}

model UserRole {
  id        String   @id @default(uuid(7))
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  scope     Json?
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, roleId])
  @@index([tenantId])
  @@map("user_role")
}

model RefreshToken {
  id        String    @id @default(uuid(7))
  tenantId  String    @map("tenant_id")
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  family    String
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId])
  @@map("refresh_token")
}

// ─────────────────────────── Org spine (tenant-scoped, RLS) ───────────────────────────

model LegalEntity {
  id          String   @id @default(uuid(7))
  tenantId    String   @map("tenant_id")
  name        String
  countryCode String   @map("country_code")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String?  @map("created_by")
  updatedBy   String?  @map("updated_by")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  departments       Department[]
  costCenters       CostCenter[]
  employmentRecords EmploymentRecord[]
  payGroups         PayGroup[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("legal_entity")
}

model Department {
  id            String   @id @default(uuid(7))
  tenantId      String   @map("tenant_id")
  legalEntityId String?  @map("legal_entity_id")
  name          String
  parentId      String?  @map("parent_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  legalEntity       LegalEntity?       @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)
  parent            Department?        @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children          Department[]       @relation("DepartmentHierarchy")
  employees         Employee[]
  employmentRecords EmploymentRecord[]

  @@index([tenantId])
  @@map("department")
}

// ─────────────────────────── Audit (append-only) ───────────────────────────

model AuditEvent {
  id          String   @id @default(uuid(7))
  tenantId    String?  @map("tenant_id")
  actorType   String   @map("actor_type")
  actorUserId String?  @map("actor_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  before      Json?
  after       Json?
  requestId   String?  @map("request_id")
  ip          String?
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_event")
}

// ─────────────────────────── Org & employees (tenant-scoped, RLS) — Phase 2 ───────────────────────────

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum PayFrequency {
  ANNUAL
  MONTHLY
  SEMI_MONTHLY
  BIWEEKLY
  WEEKLY
}

model Location {
  id          String   @id @default(uuid(7))
  tenantId    String   @map("tenant_id")
  name        String
  countryCode String   @map("country_code")
  city        String?
  timezone    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String?  @map("created_by")
  updatedBy   String?  @map("updated_by")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("location")
}

model CostCenter {
  id            String   @id @default(uuid(7))
  tenantId      String   @map("tenant_id")
  legalEntityId String?  @map("legal_entity_id")
  code          String
  name          String
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdBy     String?  @map("created_by")
  updatedBy     String?  @map("updated_by")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  legalEntity LegalEntity? @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)
  employees   Employee[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("cost_center")
}

model Employee {
  id              String         @id @default(uuid(7))
  tenantId        String         @map("tenant_id")
  employeeNumber  String         @map("employee_number")
  userId          String?        @unique @map("user_id")
  firstName       String         @map("first_name")
  lastName        String         @map("last_name")
  workEmail       String?        @map("work_email")
  status          EmployeeStatus @default(ACTIVE)
  hireDate        DateTime       @map("hire_date") @db.Date
  terminationDate DateTime?      @map("termination_date") @db.Date
  departmentId    String?        @map("department_id")
  locationId      String?        @map("location_id")
  costCenterId    String?        @map("cost_center_id")
  managerId       String?        @map("manager_id")
  payGroupId      String?        @map("pay_group_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  createdBy       String?        @map("created_by")
  updatedBy       String?        @map("updated_by")
  deletedAt       DateTime?      @map("deleted_at")

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  department          Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  location            Location?            @relation(fields: [locationId], references: [id], onDelete: SetNull)
  costCenter          CostCenter?          @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  manager             Employee?            @relation("EmployeeManager", fields: [managerId], references: [id], onDelete: SetNull)
  reports             Employee[]           @relation("EmployeeManager")
  payGroup            PayGroup?            @relation(fields: [payGroupId], references: [id], onDelete: SetNull)
  employmentRecords   EmploymentRecord[]
  compensationRecords CompensationRecord[]
  payrollRunLines     PayrollRunLine[]
  anomalies           Anomaly[]
  payslipDocuments    PayslipDocument[]
  leaveBalances       LeaveBalance[]
  leaveRequests       LeaveRequest[]
  claims              Claim[]

  @@unique([tenantId, employeeNumber])
  @@index([tenantId])
  @@index([tenantId, departmentId])
  @@index([tenantId, managerId])
  @@index([tenantId, payGroupId])
  @@map("employee")
}

model EmploymentRecord {
  id             String         @id @default(uuid(7))
  tenantId       String         @map("tenant_id")
  employeeId     String         @map("employee_id")
  employmentType EmploymentType @map("employment_type")
  jobTitle       String         @map("job_title")
  legalEntityId  String?        @map("legal_entity_id")
  departmentId   String?        @map("department_id")
  effectiveFrom  DateTime       @map("effective_from") @db.Date
  effectiveTo    DateTime?      @map("effective_to") @db.Date
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  createdBy      String?        @map("created_by")
  updatedBy      String?        @map("updated_by")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee    Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  legalEntity LegalEntity? @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)
  department  Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, employeeId])
  @@map("employment_record")
}

model CompensationRecord {
  id            String       @id @default(uuid(7))
  tenantId      String       @map("tenant_id")
  employeeId    String       @map("employee_id")
  // Money: integer minor units (e.g. cents) + ISO-4217 currency — never floats (CLAUDE.md §Conventions).
  // BigInt so zero-decimal / high-denomination currencies (IDR, VND) can't overflow a 32-bit int.
  amountMinor   BigInt       @map("amount_minor")
  currencyCode  String       @map("currency_code")
  frequency     PayFrequency
  effectiveFrom DateTime     @map("effective_from") @db.Date
  effectiveTo   DateTime?    @map("effective_to") @db.Date
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  createdBy     String?      @map("created_by")
  updatedBy     String?      @map("updated_by")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId])
  @@map("compensation_record")
}

// ─────────────────────────── Pay groups, calendars & periods (tenant-scoped, RLS) — Phase 3 ───────────────────────────

enum PayPeriodStatus {
  OPEN // generated; accepting inputs
  LOCKED // a payroll run is in progress / calculated
  PAID // published and disbursed
}

// A set of employees paid together on one schedule, in one currency, under one country rule pack.
model PayGroup {
  id            String       @id @default(uuid(7))
  tenantId      String       @map("tenant_id")
  legalEntityId String?      @map("legal_entity_id")
  code          String
  name          String
  // Country rule pack to apply (ISO 3166-1 alpha-2; e.g. "US", "GB", "IN") — see @payce/payroll-core.
  countryCode   String       @map("country_code")
  // Payout currency (ISO 4217); must match the rule pack's currency.
  currencyCode  String       @map("currency_code")
  frequency     PayFrequency
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  createdBy     String?      @map("created_by")
  updatedBy     String?      @map("updated_by")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  legalEntity LegalEntity? @relation(fields: [legalEntityId], references: [id], onDelete: SetNull)
  calendar    PayCalendar?
  periods     PayPeriod[]
  members     Employee[]
  runs        PayrollRun[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("pay_group")
}

// Generation parameters for a pay group's periods (1:1 with the group).
model PayCalendar {
  id                String   @id @default(uuid(7))
  tenantId          String   @map("tenant_id")
  payGroupId        String   @unique @map("pay_group_id")
  // First period's start date; the frequency drives every subsequent boundary.
  anchorDate        DateTime @map("anchor_date") @db.Date
  // Days after a period's end that pay lands (pay date = period end + offset).
  payDateOffsetDays Int      @default(0) @map("pay_date_offset_days")
  timezone          String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  createdBy         String?  @map("created_by")
  updatedBy         String?  @map("updated_by")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payGroup PayGroup @relation(fields: [payGroupId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("pay_calendar")
}

// A concrete pay period materialized from the calendar. Dates are calendar dates (no tz).
model PayPeriod {
  id         String          @id @default(uuid(7))
  tenantId   String          @map("tenant_id")
  payGroupId String          @map("pay_group_id")
  sequence   Int
  startDate  DateTime        @map("start_date") @db.Date
  endDate    DateTime        @map("end_date") @db.Date
  payDate    DateTime        @map("pay_date") @db.Date
  status     PayPeriodStatus @default(OPEN)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  createdBy  String?         @map("created_by")
  updatedBy  String?         @map("updated_by")

  tenant   Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payGroup PayGroup    @relation(fields: [payGroupId], references: [id], onDelete: Cascade)
  run      PayrollRun?

  @@unique([tenantId, payGroupId, sequence])
  @@index([tenantId, payGroupId])
  @@map("pay_period")
}

// ─────────────────────────── Payroll runs & maker-checker approvals (tenant-scoped, RLS) — Phase 3 ───────────────────────────

enum PayrollRunStatus {
  DRAFT // created, not yet calculated
  CALCULATED // per-employee lines computed; editable (recalculable)
  PENDING_APPROVAL // submitted by a maker, awaiting a checker
  APPROVED // approved by a different user (maker-checker satisfied)
  PUBLISHED // disbursed; immutable
  REJECTED // checker sent it back for correction
}

enum ApprovalDecision {
  APPROVE
  REJECT
}

// One immutable calculation of a pay group for a pay period. A published run reproduces exactly from
// its stored snapshot (country, rule-pack version, currency, frequency) and lines.
model PayrollRun {
  id              String           @id @default(uuid(7))
  tenantId        String           @map("tenant_id")
  payGroupId      String           @map("pay_group_id")
  payPeriodId     String           @unique @map("pay_period_id")
  status          PayrollRunStatus @default(DRAFT)
  // Reproducibility snapshot, frozen at calculation time.
  countryCode     String?          @map("country_code")
  rulePackVersion String?          @map("rule_pack_version")
  currencyCode    String?          @map("currency_code")
  frequency       PayFrequency?
  // Aggregate totals across all lines (minor units; BigInt so large fleets / zero-decimal currencies fit).
  grossMinor      BigInt?          @map("gross_minor")
  deductionsMinor BigInt?          @map("deductions_minor")
  netMinor        BigInt?          @map("net_minor")
  employeeCount   Int              @default(0) @map("employee_count")
  // Maker-checker trail (segregation of duties; golden rule 7).
  submittedBy     String?          @map("submitted_by")
  submittedAt     DateTime?        @map("submitted_at")
  approvedBy      String?          @map("approved_by")
  approvedAt      DateTime?        @map("approved_at")
  publishedBy     String?          @map("published_by")
  publishedAt     DateTime?        @map("published_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  createdBy       String?          @map("created_by")
  updatedBy       String?          @map("updated_by")

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payGroup         PayGroup          @relation(fields: [payGroupId], references: [id], onDelete: Cascade)
  payPeriod        PayPeriod         @relation(fields: [payPeriodId], references: [id], onDelete: Cascade)
  lines            PayrollRunLine[]
  approvals        Approval[]
  anomalies        Anomaly[]
  payslipDocuments PayslipDocument[]
  bankFile         BankFile?
  claims           Claim[]

  @@index([tenantId, payGroupId])
  @@map("payroll_run")
}

// A per-employee result within a run. `lines` is the full earning/deduction breakdown (payroll-core
// PayslipLine[]). Replaced wholesale on recalculation; immutable once the run is published.
model PayrollRunLine {
  id              String   @id @default(uuid(7))
  tenantId        String   @map("tenant_id")
  payrollRunId    String   @map("payroll_run_id")
  employeeId      String   @map("employee_id")
  currencyCode    String   @map("currency_code")
  grossMinor      BigInt   @map("gross_minor")
  deductionsMinor BigInt   @map("deductions_minor")
  netMinor        BigInt   @map("net_minor")
  lines           Json
  createdAt       DateTime @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, payrollRunId, employeeId])
  @@index([tenantId, payrollRunId])
  @@map("payroll_run_line")
}

// Append-only maker-checker decision log for a run.
model Approval {
  id           String           @id @default(uuid(7))
  tenantId     String           @map("tenant_id")
  payrollRunId String           @map("payroll_run_id")
  decision     ApprovalDecision
  actorUserId  String           @map("actor_user_id")
  note         String?
  createdAt    DateTime         @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@index([tenantId, payrollRunId])
  @@map("approval")
}

// Anomaly detected during payroll calculation — persisted per run, replaced on recalculation.
model Anomaly {
  id           String   @id @default(uuid(7))
  tenantId     String   @map("tenant_id")
  payrollRunId String   @map("payroll_run_id")
  employeeId   String   @map("employee_id")
  type         String
  severity     String
  detail       Json
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, payrollRunId])
  @@map("anomaly")
}

// One PDF payslip document per (run, employee). Stored in S3; s3Key is used to generate presigned
// download URLs on demand. Created on publish; immutable thereafter.
model PayslipDocument {
  id           String   @id @default(uuid(7))
  tenantId     String   @map("tenant_id")
  payrollRunId String   @map("payroll_run_id")
  employeeId   String   @map("employee_id")
  s3Key        String   @map("s3_key")
  sizeBytes    Int      @map("size_bytes")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([payrollRunId, employeeId])
  @@index([tenantId, payrollRunId])
  @@map("payslip_document")
}

// One payment-instruction CSV per published payroll run. Stored in S3; s3Key generates presigned
// download URLs on demand. Immutable after creation.
model BankFile {
  id           String   @id @default(uuid(7))
  tenantId     String   @map("tenant_id")
  payrollRunId String   @unique @map("payroll_run_id")
  s3Key        String   @map("s3_key")
  sizeBytes    Int      @map("size_bytes")
  format       String   @default("CSV")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payrollRun PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("bank_file")
}

// ─────────────────────── Phase 4 — Time, leave & claims ─────────────────────

// Configurable leave categories per tenant (annual, sick, maternity, etc.).
model LeaveType {
  id           String   @id @default(uuid(7))
  tenantId     String   @map("tenant_id")
  code         String
  name         String
  isPaid       Boolean  @default(true) @map("is_paid")
  accrualDays  Float?   @map("accrual_days") // default annual entitlement (days)
  carryOverMax Float?   @map("carry_over_max") // max days to carry to next year
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdBy    String?  @map("created_by")
  updatedBy    String?  @map("updated_by")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("leave_type")
}

// Per-employee, per-leave-type annual balance. HR initialises; system adjusts on request lifecycle.
model LeaveBalance {
  id           String   @id @default(uuid(7))
  tenantId     String   @map("tenant_id")
  employeeId   String   @map("employee_id")
  leaveTypeId  String   @map("leave_type_id")
  year         Int
  entitledDays Float    @map("entitled_days")
  usedDays     Float    @default(0) @map("used_days")
  pendingDays  Float    @default(0) @map("pending_days")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, leaveTypeId, year])
  @@index([tenantId, employeeId])
  @@map("leave_balance")
}

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// Employee leave request with manager approval workflow.
model LeaveRequest {
  id          String             @id @default(uuid(7))
  tenantId    String             @map("tenant_id")
  employeeId  String             @map("employee_id")
  leaveTypeId String             @map("leave_type_id")
  startDate   DateTime           @map("start_date") @db.Date
  endDate     DateTime           @map("end_date") @db.Date
  days        Float
  note        String?
  status      LeaveRequestStatus @default(PENDING)
  reviewedBy  String?            @map("reviewed_by")
  reviewedAt  DateTime?          @map("reviewed_at")
  reviewNote  String?            @map("review_note")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  createdBy   String?            @map("created_by")
  updatedBy   String?            @map("updated_by")

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee  Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("leave_request")
}

enum ClaimStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// Employee expense/reimbursement claim with manager approval workflow. Approved (unpaid) claims feed
// into payroll as a reimbursement input for the period in which they were incurred.
model Claim {
  id           String      @id @default(uuid(7))
  tenantId     String      @map("tenant_id")
  employeeId   String      @map("employee_id")
  category     String // e.g. TRAVEL, MEALS, EQUIPMENT — free-form category, validated at the boundary
  title        String
  amountMinor  BigInt      @map("amount_minor") // integer minor units (never float — money rule)
  currencyCode String      @map("currency_code")
  incurredOn   DateTime    @map("incurred_on") @db.Date
  status       ClaimStatus @default(PENDING)
  note         String?
  reviewedBy   String?     @map("reviewed_by")
  reviewedAt   DateTime?   @map("reviewed_at")
  reviewNote   String?     @map("review_note")
  // Set when the claim is consumed by a published payroll run (idempotent — prevents double-payment).
  payrollRunId String?     @map("payroll_run_id")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  createdBy    String?     @map("created_by")
  updatedBy    String?     @map("updated_by")

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee    Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollRun  PayrollRun?       @relation(fields: [payrollRunId], references: [id], onDelete: SetNull)
  attachments ClaimAttachment[]

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@map("claim")
}

// Receipt/document attached to a claim. The binary lives in S3; we store only the object key + metadata.
model ClaimAttachment {
  id          String   @id @default(uuid(7))
  tenantId    String   @map("tenant_id")
  claimId     String   @map("claim_id")
  s3Key       String   @map("s3_key")
  fileName    String   @map("file_name")
  contentType String   @map("content_type")
  sizeBytes   Int      @map("size_bytes")
  createdAt   DateTime @default(now()) @map("created_at")
  createdBy   String?  @map("created_by")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  claim  Claim  @relation(fields: [claimId], references: [id], onDelete: Cascade)

  @@index([tenantId, claimId])
  @@map("claim_attachment")
}
