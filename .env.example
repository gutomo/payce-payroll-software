# Local development environment.
# Synthetic/dev values only; NEVER put real secrets or real PII here.
# In AWS, all secrets come from Secrets Manager / SSM (see docs/aws-architecture.md §7).

NODE_ENV=development

# Web (Next.js)
WEB_PORT=3000
NEXT_PUBLIC_APP_NAME=Payce
# Server-side base URL the web app uses to reach the API. The browser never calls the API directly
# (Next.js proxies every call server-side), so this is NOT a NEXT_PUBLIC_* value.
API_BASE_URL=http://localhost:4000/api/v1

# API (NestJS)
API_PORT=4000

# Postgres (docker compose)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=payce
POSTGRES_PASSWORD=payce_dev_password
POSTGRES_DB=payce_dev
# App/runtime connection: least-privilege role, subject to Row-Level Security.
DATABASE_URL=postgresql://payce_app:payce_app_dev_password@localhost:5432/payce_dev?schema=public
# Migrations/introspection connection: schema owner (Prisma directUrl).
DIRECT_DATABASE_URL=postgresql://payce:payce_dev_password@localhost:5432/payce_dev?schema=public

# Redis (docker compose)
REDIS_URL=redis://localhost:6379

# Enterprise SSO (optional). Dev/demo uses the seeded OFFLINE test IdP, which needs no secret. Only set
# this to exercise a REAL OIDC provider locally; in staging/prod the client secret is read from Secrets
# Manager via the provider's clientSecretRef, never from env (golden rule 3).
# OIDC_CLIENT_SECRET=

# LocalStack (AWS emulation)
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
